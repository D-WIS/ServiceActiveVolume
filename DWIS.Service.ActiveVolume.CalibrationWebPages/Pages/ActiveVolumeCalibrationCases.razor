        ActiveVolumeSignalKind.CoriolisVolumetricFlowrate => "MUD_FLOW_OUT",
        ActiveVolumeSignalKind.ReturnMudDensity => "MUD_DENS_OUT",
        ActiveVolumeSignalKind.CuttingsRecoveryRate => "CRR_ALL",
        ActiveVolumeSignalKind.CuttingsP50Size => "CSD_P50",
        ActiveVolumeSignalKind.StandPipePressure => "PUMP_PRESS",
        ActiveVolumeSignalKind.BottomOfStringDepth => "DEPTH_BIT",
        ActiveVolumeSignalKind.BottomHoleDepth => "DEPTH_HOLE",
        ActiveVolumeSignalKind.InletMudTemperature => "TEMP_IN",
        ActiveVolumeSignalKind.OutletMudTemperature => "TEMP_OUT",
        _ => signalKind.ToString()
    };

