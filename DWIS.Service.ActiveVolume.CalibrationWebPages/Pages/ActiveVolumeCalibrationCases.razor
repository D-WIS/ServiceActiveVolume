            return;
        }

        currentCase_.FieldID = fieldId ?? Guid.Empty;
        currentCase_.ClusterID = Guid.Empty;
        currentCase_.WellID = Guid.Empty;
        currentCase_.WellBoreID = Guid.Empty;
        currentCase_.WellBoreArchitectureID = Guid.Empty;
        currentCase_.DrillStringID = Guid.Empty;
        UpdateDerivedContextFields();
    }

    private void OnClusterChanged(Guid? clusterId)
    {
        if (currentCase_ is null)
        {
            return;
        }

        currentCase_.ClusterID = clusterId ?? Guid.Empty;
        if (clusterId is Guid selectedClusterId)
        {
            ClusterLight? cluster = clusterList_.FirstOrDefault(item => item.MetaInfo?.ID == selectedClusterId);
            currentCase_.FieldID = cluster?.FieldID ?? currentCase_.FieldID;
        }

        currentCase_.WellID = Guid.Empty;
        currentCase_.WellBoreID = Guid.Empty;
        currentCase_.WellBoreArchitectureID = Guid.Empty;
        currentCase_.DrillStringID = Guid.Empty;
        UpdateDerivedContextFields();
    }

    private void OnWellChanged(Guid? wellId)
    {
        if (currentCase_ is null)
        {
            return;
        }

        currentCase_.WellID = wellId ?? Guid.Empty;
        if (wellId is Guid selectedWellId)
        {
            Well? well = wellList_.FirstOrDefault(item => item.MetaInfo?.ID == selectedWellId);
            currentCase_.ClusterID = well?.ClusterID ?? currentCase_.ClusterID;
            if (currentCase_.ClusterID != Guid.Empty)
            {
                ClusterLight? cluster = clusterList_.FirstOrDefault(item => item.MetaInfo?.ID == currentCase_.ClusterID);
                currentCase_.FieldID = cluster?.FieldID ?? currentCase_.FieldID;
            }
        }

        currentCase_.WellBoreID = Guid.Empty;
        currentCase_.WellBoreArchitectureID = Guid.Empty;
        currentCase_.DrillStringID = Guid.Empty;
        UpdateDerivedContextFields();
    }

    private void OnWellBoreChanged(Guid? wellBoreId)
    {
        if (currentCase_ is null)
        {
            return;
        }

        ApplyWellBoreContext(wellBoreId);
        currentCase_.WellBoreArchitectureID = Guid.Empty;
        currentCase_.DrillStringID = Guid.Empty;
        UpdateDerivedContextFields();
    }

    private void OnWellBoreArchitectureChanged(Guid? architectureId)
    {
        if (currentCase_ is null)
        {
            return;
        }

        currentCase_.WellBoreArchitectureID = architectureId ?? Guid.Empty;
        if (architectureId is Guid selectedArchitectureId)
        {
            WellBoreArchitecture? architecture = wellBoreArchitectureList_.FirstOrDefault(item => item.MetaInfo?.ID == selectedArchitectureId);
            if (architecture?.WellBoreID is Guid architectureWellBoreId && architectureWellBoreId != Guid.Empty)
            {
                if (currentCase_.WellBoreID != Guid.Empty && currentCase_.WellBoreID != architectureWellBoreId)
                {
                    currentCase_.DrillStringID = Guid.Empty;
                }

                ApplyWellBoreContext(architectureWellBoreId);
            }
        }

        UpdateDerivedContextFields();
    }

    private void OnDrillStringChanged(Guid? drillStringId)
    {
        if (currentCase_ is null)
        {
            return;
        }

        currentCase_.DrillStringID = drillStringId ?? Guid.Empty;
        if (drillStringId is Guid selectedDrillStringId)
        {
            DrillStringLight? drillString = drillStringList_.FirstOrDefault(item => item.MetaInfo?.ID == selectedDrillStringId);
            if (drillString?.WellBoreID is Guid drillStringWellBoreId && drillStringWellBoreId != Guid.Empty)
            {
                if (currentCase_.WellBoreID != Guid.Empty && currentCase_.WellBoreID != drillStringWellBoreId)
                {
                    currentCase_.WellBoreArchitectureID = Guid.Empty;
                }

                ApplyWellBoreContext(drillStringWellBoreId);
            }
        }

        UpdateDerivedContextFields();
    }

    private static string FormatDate(DateTimeOffset value) => value.ToString("u");

    private static Guid? ToNullableGuid(Guid? value) => value is Guid id && id != Guid.Empty ? id : null;

    private DelimitedImportDefinition EnsureRealtimeImportDefinition()
    {
        if (currentCase_ is null)
        {
            return CreateDefaultImportDefinition();
        }

        currentCase_.RealtimeImportDefinition ??= CreateDefaultImportDefinition();
        currentCase_.RealtimeImportDefinition.Columns ??= new List<DelimitedColumnMapping>();
        foreach (DelimitedColumnMapping mapping in currentCase_.RealtimeImportDefinition.Columns)
        {
            ApplySignalDefaults(mapping, overwriteUnit: string.IsNullOrWhiteSpace(mapping.Unit));
        }

        return currentCase_.RealtimeImportDefinition;
    }

    private static DelimitedImportDefinition CreateDefaultImportDefinition()
    {
        return new DelimitedImportDefinition
        {
            FileFormat = ActiveVolumeImportFileFormat.DelimitedText,
            Separator = DelimitedFileSeparator.Comma,
            CustomSeparator = ",",
            HasHeader = true,
            TimestampFormat = "O",
            TimestampStorageKind = TimestampStorageKind.Utc,
            LocalTimeZoneId = TimeZoneInfo.Local.Id,
            Columns = CreateDefaultImportMappings()
        };
    }

    private static List<DelimitedColumnMapping> CreateDefaultImportMappings()
    {
        ActiveVolumeSignalKind[] defaultSignals =
        {
            ActiveVolumeSignalKind.Timestamp,
            ActiveVolumeSignalKind.ActiveVolume,
            ActiveVolumeSignalKind.FlowrateIn,
            ActiveVolumeSignalKind.FlowPaddlePosition,
            ActiveVolumeSignalKind.CoriolisVolumetricFlowrate,
            ActiveVolumeSignalKind.CoriolisMassFlowrate,
            ActiveVolumeSignalKind.ReturnMudDensity,
            ActiveVolumeSignalKind.CuttingsRecoveryRate,
            ActiveVolumeSignalKind.StandPipePressure,
            ActiveVolumeSignalKind.BottomOfStringDepth,
            ActiveVolumeSignalKind.BottomHoleDepth
        };

        return defaultSignals
            .Select((signal, index) =>
            {
                DelimitedColumnMapping mapping = new()
                {
                    ColumnIndex = index,
                    FieldName = signal.ToString()
                };
                OnImportSignalKindChanged(mapping, signal);
                return mapping;
            })
            .ToList();
    }

    private void OnImportFileFormatChanged(ActiveVolumeImportFileFormat fileFormat)
    {
        RealtimeImportDefinition.FileFormat = fileFormat;
        if (fileFormat == ActiveVolumeImportFileFormat.FixedWidthText)
        {
            RealtimeImportDefinition.Separator = DelimitedFileSeparator.FixedWidth;
        }
        else if (RealtimeImportDefinition.Separator == DelimitedFileSeparator.FixedWidth)
        {
            RealtimeImportDefinition.Separator = DelimitedFileSeparator.Comma;
        }
    }

    private void AddImportColumnMapping()
    {
        DelimitedImportDefinition definition = RealtimeImportDefinition;
        definition.Columns ??= new List<DelimitedColumnMapping>();
        DelimitedColumnMapping mapping = new()
        {
            ColumnIndex = definition.Columns.Count,
            FieldName = "Signal"
        };
        OnImportSignalKindChanged(mapping, ActiveVolumeSignalKind.Ignore);
        definition.Columns.Add(mapping);
    }

    private void RemoveImportColumnMapping(DelimitedColumnMapping mapping)
    {
        RealtimeImportDefinition.Columns?.Remove(mapping);
    }

    private static void OnImportSignalKindChanged(DelimitedColumnMapping mapping, ActiveVolumeSignalKind signalKind)
    {
        mapping.SignalKind = signalKind;
        ApplySignalDefaults(mapping, overwriteUnit: true);
    }

    private static void ApplySignalDefaults(DelimitedColumnMapping mapping, bool overwriteUnit)
    {
        mapping.PhysicalQuantity = GetPhysicalQuantity(mapping.SignalKind);
        mapping.ReferenceSystem = SignalUsesDepthReference(mapping.SignalKind) ? "WGS84" : string.Empty;
        if (SignalUsesDepthReference(mapping.SignalKind) && string.IsNullOrWhiteSpace(mapping.DepthReferenceName))
        {
            mapping.DepthReferenceName = "WGS84";
        }
        else if (!SignalUsesDepthReference(mapping.SignalKind))
        {
            mapping.DepthReferenceName = string.Empty;
        }

        if (overwriteUnit)
        {
            mapping.Unit = GetDefaultUnit(mapping.SignalKind);
        }
    }

    private static bool SignalUsesDepthReference(ActiveVolumeSignalKind signalKind) =>
        signalKind is ActiveVolumeSignalKind.BottomOfStringDepth or ActiveVolumeSignalKind.BottomHoleDepth;

    private static bool SignalHasUnit(ActiveVolumeSignalKind signalKind) =>
        signalKind is not ActiveVolumeSignalKind.Ignore and not ActiveVolumeSignalKind.Timestamp;

