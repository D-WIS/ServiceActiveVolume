    private void ApplyWellBoreContext(Guid? wellBoreId)
    {
        if (currentCase_ is null)
        {
            return;
        }

        currentCase_.WellBoreID = wellBoreId ?? Guid.Empty;
        if (wellBoreId is not Guid selectedWellBoreId || selectedWellBoreId == Guid.Empty)
        {
            return;
        }

        WellBore? wellBore = wellBoreList_.FirstOrDefault(item => item.MetaInfo?.ID == selectedWellBoreId);
        currentCase_.WellID = wellBore?.WellID ?? currentCase_.WellID;
        if (currentCase_.WellID == Guid.Empty)
        {
            return;
        }

        Well? well = wellList_.FirstOrDefault(item => item.MetaInfo?.ID == currentCase_.WellID);
        currentCase_.ClusterID = well?.ClusterID ?? currentCase_.ClusterID;
        if (currentCase_.ClusterID == Guid.Empty)
        {
            return;
        }

        ClusterLight? cluster = clusterList_.FirstOrDefault(item => item.MetaInfo?.ID == currentCase_.ClusterID);
        currentCase_.FieldID = cluster?.FieldID ?? currentCase_.FieldID;
    }

    private void UpdateDerivedContextFields()
    {
        if (currentCase_ is null)
        {
            return;
        }

        currentCase_.RigName = DerivedRigName;
        currentCase_.MudSystem = DerivedMudSystem;
        currentCase_.HoleSection = DerivedHoleSection;
    }

    private string GetDerivedRigName()
    {
        Rig? rig = GetSelectedRig();
        if (rig is null)
        {
            return string.Empty;
        }

        Guid? rigId = rig.MetaInfo?.ID;
        return !string.IsNullOrWhiteSpace(rig.Name) ? rig.Name : rigId?.ToString() ?? string.Empty;
    }

    private string GetDerivedMudSystem()
    {
        Rig? rig = GetSelectedRig();
        DrillingFluidTypeDescriptor? fluidType = rig?.DrillingFluidType;
        if (fluidType is null)
        {
            return string.Empty;
        }

        if (!string.IsNullOrWhiteSpace(fluidType.Name))
        {
            return fluidType.Name;
        }

        return $"{fluidType.DrillingFluidClass} / {fluidType.DrillingFluidType}";
    }

    private string GetDerivedHoleSection()
    {
        WellBoreArchitecture? architecture = GetSelectedWellBoreArchitecture();
        CasingSection? casingSection = architecture?.CasingSections?
            .Where(section => section?.OpenHoleSection is not null)
            .LastOrDefault();
        if (casingSection?.OpenHoleSection is null)
        {
            return string.Empty;
        }

        List<string> openHoleSegments = casingSection.OpenHoleSection.HoleSizes?
            .Select(FormatOpenHoleSegment)
            .Where(item => !string.IsNullOrWhiteSpace(item))
            .ToList() ?? new List<string>();

        return openHoleSegments.Count > 0 ? string.Join("; ", openHoleSegments) : "Open hole";
    }

    private WellBore? GetSelectedWellBore()
    {
        return SelectedWellBoreId is Guid wellBoreId
            ? wellBoreList_.FirstOrDefault(item => item.MetaInfo?.ID == wellBoreId)
            : null;
    }

    private Rig? GetSelectedRig()
    {
        Guid? rigId = GetSelectedRigId();
        return rigId is Guid id
            ? rigList_.FirstOrDefault(item => item.MetaInfo?.ID == id)
            : null;
    }

    private Guid? GetSelectedRigId()
    {
        WellBore? wellBore = GetSelectedWellBore();
        if (wellBore?.RigID is Guid wellBoreRigId && wellBoreRigId != Guid.Empty)
        {
            return wellBoreRigId;
        }

        Well? well = wellBore?.WellID is Guid wellId && wellId != Guid.Empty
            ? wellList_.FirstOrDefault(item => item.MetaInfo?.ID == wellId)
            : SelectedWellId is Guid selectedWellId
                ? wellList_.FirstOrDefault(item => item.MetaInfo?.ID == selectedWellId)
                : null;

        ClusterLight? cluster = well?.ClusterID is Guid clusterId && clusterId != Guid.Empty
            ? clusterList_.FirstOrDefault(item => item.MetaInfo?.ID == clusterId)
            : SelectedClusterId is Guid selectedClusterId
                ? clusterList_.FirstOrDefault(item => item.MetaInfo?.ID == selectedClusterId)
                : null;

        return cluster is { IsFixedPlatform: true, RigID: Guid clusterRigId } && clusterRigId != Guid.Empty
            ? clusterRigId
            : null;
    }

    private WellBoreArchitecture? GetSelectedWellBoreArchitecture()
    {
        return SelectedWellBoreArchitectureId is Guid architectureId
            ? wellBoreArchitectureList_.FirstOrDefault(item => item.MetaInfo?.ID == architectureId)
            : null;
    }

    private static string FormatGaussianValue(GaussianDrillingProperty? property)
    {
        double? value = property?.GaussianValue?.Mean;
        return value?.ToString("G4") ?? string.Empty;
    }

    private string FormatOpenHoleSegment(BoreHoleSize? holeSize)
    {
        string diameter = FormatQuantityValue(holeSize?.HoleSize, "DiameterPipeDrilling");
        string length = FormatQuantityValue(holeSize?.Length, "DepthDrilling");
        if (!string.IsNullOrWhiteSpace(diameter) && !string.IsNullOrWhiteSpace(length))
        {
            return $"{diameter} x {length}";
        }

        if (!string.IsNullOrWhiteSpace(diameter))
        {
            return diameter;
        }

        return !string.IsNullOrWhiteSpace(length) ? length : string.Empty;
    }

    private string FormatQuantityValue(GaussianDrillingProperty? property, string quantityName)
    {
        double? siValue = property?.GaussianValue?.Mean;
        if (!siValue.HasValue)
        {
            return string.Empty;
        }

        double? converted = unitReferenceTag_?.FromSI(siValue, quantityName);
        string unitLabel = unitReferenceTag_?.GetUnitLabel(quantityName) ?? "m";
        return $"{(converted ?? siValue.Value):G4} {unitLabel}";
    }

    private static double ToPercent(double progress) => Math.Clamp(progress, 0.0, 1.0) * 100.0;

    private static string FormatPercent(double progress) => $"{ToPercent(progress):F0}%";

    private static string FormatCalibrationSummary(ActiveVolumeCaseLight item)
    {
        if (item.BestCalibrationID is null)
        {
            return string.Empty;
        }

        return item.CalibrationQuality is double quality ? $"{quality:F3}" : "Available";
    }

    private static ActiveVolumeCaseLight ToLight(ActiveVolumeCase activeCase)
    {
        return new ActiveVolumeCaseLight
        {
            Id = activeCase.Id,
            Name = activeCase.Name,
            FieldID = activeCase.FieldID,
            ClusterID = activeCase.ClusterID,
            WellID = activeCase.WellID,
            WellBoreID = activeCase.WellBoreID,
            WellBoreArchitectureID = activeCase.WellBoreArchitectureID,
            DrillStringID = activeCase.DrillStringID,
            ReturnFlowMeasurementMode = activeCase.ReturnFlowMeasurementMode,
            ProcessingState = activeCase.ProcessingState,
            ProcessingProgress = activeCase.ProcessingProgress,
            ProcessingMessage = activeCase.ProcessingMessage,
            LastProcessedChunkIndex = activeCase.LastProcessedChunkIndex,
            ChunkCount = activeCase.ChunkCount,
            SampleCount = activeCase.SampleCount,
            ActiveJobID = activeCase.ActiveJobID,
            BestCalibrationID = activeCase.BestCalibrationID,
            CalibrationQuality = activeCase.CalibrationQuality,
            LastCalibrationDate = activeCase.LastCalibrationDate,
            CreationDate = activeCase.CreationDate,
            LastModificationDate = activeCase.LastModificationDate
        };
    }

    private static Color GetProcessingColor(ActiveVolumeCaseProcessingState state) => state switch
    {
        ActiveVolumeCaseProcessingState.Processed => Color.Success,
        ActiveVolumeCaseProcessingState.Failed or ActiveVolumeCaseProcessingState.Interrupted => Color.Error,
        ActiveVolumeCaseProcessingState.Queued or ActiveVolumeCaseProcessingState.Processing or ActiveVolumeCaseProcessingState.Uploading => Color.Info,
        _ => Color.Default
    };

    private static Color GetProcessingProgressColor(ActiveVolumeCaseProcessingState state) => state switch
    {
        ActiveVolumeCaseProcessingState.Processed => Color.Success,
        ActiveVolumeCaseProcessingState.Failed or ActiveVolumeCaseProcessingState.Interrupted => Color.Error,
        _ => Color.Info
    };
