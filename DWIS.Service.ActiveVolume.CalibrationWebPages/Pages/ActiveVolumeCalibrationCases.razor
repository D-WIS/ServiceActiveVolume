@page "/activevolumecalibration/cases"
@inject IActiveVolumeCalibrationAPIUtils Api
@inject ISnackbar Snackbar

@if (!isEditing_)
{
    <MudStack Spacing="3">
        <MudStack Row AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h6">Active Volume Cases</MudText>
            <MudButton OnClick="CreateCaseAsync" Color="@Color.Success" Class="add-item-btn">Add</MudButton>
            <MudButton OnClick="DeleteSelectedCasesAsync" Color="@Color.Error" Class="add-item-btn" Disabled="@(!selectedCases_.Any() || isBusy_)">Delete</MudButton>
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ReloadCasesAsync">Refresh</MudButton>
        </MudStack>

        @if (cases_ is null)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else
        {
            <MudTable Items="@cases_" T="ActiveVolumeCaseLight" MultiSelection="true" @bind-SelectedItems="selectedCases_" Hover="true" Dense="true" Bordered="true" OnRowClick="OnCaseRowClicked">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Progress</MudTh>
                    <MudTh>Return Flow</MudTh>
                    <MudTh>Calibration</MudTh>
                    <MudTh>Last Updated</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">@context.Name</MudTd>
                    <MudTd DataLabel="Status">
                        <MudText Color="@GetProcessingColor(context.ProcessingState)">@context.ProcessingState</MudText>
                        @if (!string.IsNullOrWhiteSpace(context.ProcessingMessage))
                        {
                            <MudText Typo="Typo.caption">@context.ProcessingMessage</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Progress">
                        <MudProgressLinear Value="@ToPercent(context.ProcessingProgress)" Color="@GetProcessingProgressColor(context.ProcessingState)" />
                        <MudText Typo="Typo.caption">@FormatPercent(context.ProcessingProgress)</MudText>
                    </MudTd>
                    <MudTd DataLabel="Return Flow">@FormatReturnFlowMeasurementMode(context.ReturnFlowMeasurementMode)</MudTd>
                    <MudTd DataLabel="Calibration">@FormatCalibrationSummary(context)</MudTd>
                    <MudTd DataLabel="Last Updated">@FormatDate(context.LastModificationDate)</MudTd>
                    <MudTd>
                        <span @onclick:stopPropagation="true">
                            <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="(() => DeleteCaseAsync(context))" />
                        </span>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText>No cases have been stored yet.</MudText>
                </NoRecordsContent>
            </MudTable>
        }
    </MudStack>
}
else
{
    <MudUnitAndReferenceChoiceTag @ref="unitReferenceTag_"
                                  HttpHost="@Api.HostNameUnitConversion"
                                  HttpBasePath="@Api.HostBasePathUnitConversion"
                                  HttpController="UnitSystem/"
                                  UnitSystemName="@ActiveVolumeCalibrationUnitAndReferenceDataUtils.UnitAndReferenceParameters.UnitSystemName"
                                  UnitSystemNameChanged="@ActiveVolumeCalibrationUnitAndReferenceDataUtils.UpdateUnitSystemName"
                                  DepthReferenceName="@ActiveVolumeCalibrationUnitAndReferenceDataUtils.UnitAndReferenceParameters.DepthReferenceName"
                                  DepthReferenceNameChanged="@ActiveVolumeCalibrationUnitAndReferenceDataUtils.UpdateDepthReferenceName"
                                  GroundMudLineDepthReferenceSource="@ActiveVolumeCalibrationUnitAndReferenceDataUtils.GroundMudLineDepthReferenceSource"
                                  MeanSeaLevelDepthReferenceSource="@ActiveVolumeCalibrationUnitAndReferenceDataUtils.MeanSeaLevelDepthReferenceSource"
                                  SeaWaterLevelDepthReferenceSource="@ActiveVolumeCalibrationUnitAndReferenceDataUtils.SeaWaterLevelDepthReferenceSource"
                                  RotaryTableDepthReferenceSource="@ActiveVolumeCalibrationUnitAndReferenceDataUtils.RotaryTableDepthReferenceSource">
    <MudStack Spacing="3">
        <MudStack Row AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h5">Edit Active Volume Case</MudText>
            <MudSpacer />
            <MudContainer Class="d-flex flex-row justify-end pa-0">
                <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Success" OnClick="SaveCaseAsync" Disabled="@(currentCase_ is null || isBusy_)">Save</MudButton>
                <MudButton Class="me-1" Variant="Variant.Outlined" Color="Color.Primary" OnClick="ProcessCaseAsync" Disabled="@(currentCase_ is null || isBusy_)">Process</MudButton>
                <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Error" OnClick="CloseEditorAsync">Close</MudButton>
            </MudContainer>
        </MudStack>

        @if (selectedCaseLight_ is not null)
        {
            <MudPaper Class="pa-3" Elevation="1">
                <MudGrid>
                    <MudItem xs="12" md="3">
                        <MudText Typo="Typo.caption">Status</MudText>
                        <MudText Color="@GetProcessingColor(selectedCaseLight_.ProcessingState)">@selectedCaseLight_.ProcessingState</MudText>
                    </MudItem>
                    <MudItem xs="12" md="5">
                        <MudText Typo="Typo.caption">Processing</MudText>
                        <MudProgressLinear Value="@ToPercent(selectedCaseLight_.ProcessingProgress)" Color="@GetProcessingProgressColor(selectedCaseLight_.ProcessingState)" />
                        <MudText Typo="Typo.caption">@selectedCaseLight_.ProcessingMessage</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        }

        @if (isLoadingCase_)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (currentCase_ is not null)
        {
            <MudPaper Class="pa-4" Elevation="1">
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="currentCase_.Name" Label="Name" Required="true" ShrinkLabel />
                    </MudItem>
                    <MudItem xs="12" md="8">
                        <MudTextField @bind-Value="currentCase_.Description" Label="Description" ShrinkLabel />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudSelect T="ReturnFlowMeasurementMode" Label="Return flow measurement" Value="@currentCase_.ReturnFlowMeasurementMode" ValueChanged="OnReturnFlowMeasurementModeChanged" ShrinkLabel>
                            @foreach (ReturnFlowMeasurementMode mode in ReturnFlowMeasurementModes)
                            {
                                <MudSelectItem T="ReturnFlowMeasurementMode" Value="@mode">@FormatReturnFlowMeasurementMode(mode)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudGrid>
                            <MudItem xs="12" md="4">
                                <MudSelect T="Guid?" Label="Field" Value="@SelectedFieldId" ValueChanged="OnFieldChanged" ShrinkLabel Clearable="true">
                                    @foreach (FieldLight field in AvailableFields)
                                    {
                                        <MudSelectItem T="Guid?" Value="@field.MetaInfo.ID">@field.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="Guid?" Label="Cluster" Value="@SelectedClusterId" ValueChanged="OnClusterChanged" ShrinkLabel Clearable="true">
                                    @foreach (ClusterLight cluster in AvailableClusters)
                                    {
                                        <MudSelectItem T="Guid?" Value="@cluster.MetaInfo.ID">@cluster.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="Guid?" Label="Well" Value="@SelectedWellId" ValueChanged="OnWellChanged" ShrinkLabel Clearable="true">
                                    @foreach (Well well in AvailableWells)
                                    {
                                        <MudSelectItem T="Guid?" Value="@well.MetaInfo.ID">@well.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="Guid?" Label="WellBore" Value="@SelectedWellBoreId" ValueChanged="OnWellBoreChanged" ShrinkLabel Clearable="true">
                                    @foreach (WellBore wellBore in AvailableWellBores)
                                    {
                                        <MudSelectItem T="Guid?" Value="@wellBore.MetaInfo.ID">@wellBore.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="Guid?" Label="WellBore Architecture" Value="@SelectedWellBoreArchitectureId" ValueChanged="OnWellBoreArchitectureChanged" ShrinkLabel Clearable="true">
                                    @foreach (WellBoreArchitecture architecture in AvailableWellBoreArchitectures)
                                    {
                                        <MudSelectItem T="Guid?" Value="@architecture.MetaInfo.ID">@architecture.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="Guid?" Label="Drill String" Value="@SelectedDrillStringId" ValueChanged="OnDrillStringChanged" ShrinkLabel Clearable="true">
                                    @foreach (DrillStringLight drillString in AvailableDrillStrings)
                                    {
                                        <MudSelectItem T="Guid?" Value="@drillString.MetaInfo.ID">@drillString.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                    </MudItem>
                    <MudItem xs="12">
                        <MudGrid>
                            <MudItem xs="12" md="4">
                                <MudTextField Value="@DerivedRigName" Label="Rig" ReadOnly="true" ShrinkLabel />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField Value="@DerivedMudSystem" Label="Mud system" ReadOnly="true" ShrinkLabel />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField Value="@DerivedHoleSection" Label="Hole section" ReadOnly="true" ShrinkLabel />
                            </MudItem>
                        </MudGrid>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudExpansionPanels Elevation="1">
                <MudExpansionPanel Text="Realtime Data Import">
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="RealtimeImportDefinition.FileName" Label="File name" ShrinkLabel />
                        </MudItem>
                        <MudItem xs="12" md="6" Class="d-flex align-center">
                            <InputFile OnChange="OnRealtimeImportFileSelected" />
                        </MudItem>
                        <MudItem xs="12" md="3" Class="d-flex align-center">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ImportRealtimeDataAsync" Disabled="@(!CanImportRealtimeData)">Import</MudButton>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudSelect T="ActiveVolumeImportFileFormat" Label="File format" Value="@RealtimeImportDefinition.FileFormat" ValueChanged="OnImportFileFormatChanged" ShrinkLabel>
                                @foreach (ActiveVolumeImportFileFormat format in Enum.GetValues<ActiveVolumeImportFileFormat>())
                                {
                                    <MudSelectItem T="ActiveVolumeImportFileFormat" Value="@format">@FormatImportFileFormat(format)</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        @if (RealtimeImportDefinition.FileFormat == ActiveVolumeImportFileFormat.DelimitedText)
                        {
                            <MudItem xs="12" md="3">
                                <MudSelect T="DelimitedFileSeparator" Label="Separator" @bind-Value="RealtimeImportDefinition.Separator" ShrinkLabel>
                                    @foreach (DelimitedFileSeparator separator in DelimitedSeparators)
                                    {
                                        <MudSelectItem T="DelimitedFileSeparator" Value="@separator">@FormatSeparator(separator)</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudTextField @bind-Value="RealtimeImportDefinition.CustomSeparator" Label="Custom separator" ShrinkLabel Disabled="@(RealtimeImportDefinition.Separator != DelimitedFileSeparator.Custom)" />
                            </MudItem>
                            <MudItem xs="12" md="3" Class="d-flex align-center">
                                <MudCheckBox T="bool" @bind-Value="RealtimeImportDefinition.HasHeader" Label="Header row" />
                            </MudItem>
                        }
                        else if (RealtimeImportDefinition.FileFormat == ActiveVolumeImportFileFormat.FixedWidthText)
                        {
                            <MudItem xs="12" md="3" Class="d-flex align-center">
                                <MudCheckBox T="bool" @bind-Value="RealtimeImportDefinition.HasHeader" Label="Header row" />
                            </MudItem>
                        }
                        @if (ShowTimestampImportControls)
                        {
                            <MudItem xs="12" md="3">
                                <MudTextField @bind-Value="RealtimeImportDefinition.TimestampFormat" Label="Timestamp format" ShrinkLabel />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudSelect T="TimestampStorageKind" Label="Timestamp zone" @bind-Value="RealtimeImportDefinition.TimestampStorageKind" ShrinkLabel>
                                    @foreach (TimestampStorageKind kind in Enum.GetValues<TimestampStorageKind>())
                                    {
                                        <MudSelectItem T="TimestampStorageKind" Value="@kind">@FormatTimestampKind(kind)</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="string" Label="Local time zone" @bind-Value="RealtimeImportDefinition.LocalTimeZoneId" ShrinkLabel Clearable="true" Disabled="@(RealtimeImportDefinition.TimestampStorageKind != TimestampStorageKind.LocalTime)">
                                    @foreach (string timeZoneId in TimeZoneIds)
                                    {
                                        <MudSelectItem T="string" Value="@timeZoneId">@timeZoneId</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        }
                    </MudGrid>

                    <MudStack Row AlignItems="AlignItems.Center" Class="mt-4">
                        <MudText Typo="Typo.subtitle1">Signal mappings</MudText>
                        <MudButton OnClick="AddImportColumnMapping" Color="@Color.Success" Class="add-item-btn">Add</MudButton>
                        <MudButton OnClick="DeleteSelectedImportColumnMappings" Color="@Color.Error" Class="add-item-btn" Disabled="@(!selectedImportColumns_.Any())">Delete</MudButton>
                    </MudStack>
                    <MudTable Items="@ImportColumns" T="DelimitedColumnMapping" MultiSelection="true" @bind-SelectedItems="selectedImportColumns_" Dense="true" Hover="true" Bordered="true">
                        <HeaderContent>
                            <MudTh>Signal</MudTh>
                            @if (ShowImportSourceColumn)
                            {
                                <MudTh>Source</MudTh>
                            }
                            @if (ShowFixedWidthColumn)
                            {
                                <MudTh>Fixed width</MudTh>
                            }
                            <MudTh>Quantity</MudTh>
                            <MudTh>Unit</MudTh>
                            <MudTh>Depth reference</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Signal">
                                <MudSelect T="ActiveVolumeSignalKind" Value="@context.SignalKind" ValueChanged="@((ActiveVolumeSignalKind signalKind) => OnImportSignalKindChanged(context, signalKind))" Dense="true" ShrinkLabel>
                                    @foreach (ActiveVolumeSignalKind signalKind in GetImportableSignalKinds())
                                    {
                                        <MudSelectItem T="ActiveVolumeSignalKind" Value="@signalKind">@FormatSignalKind(signalKind)</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudTd>
                            @if (ShowImportSourceColumn)
                            {
                                <MudTd DataLabel="Source">
                                    @if (RealtimeImportDefinition.FileFormat == ActiveVolumeImportFileFormat.Parquet)
                                    {
                                        <MudTextField @bind-Value="context.FieldName" Label="Field" ShrinkLabel />
                                    }
                                    else
                                    {
                                        <MudNumericField T="int" @bind-Value="context.ColumnIndex" Label="Column" Min="0" ShrinkLabel />
                                    }
                                </MudTd>
                            }
                            @if (ShowFixedWidthColumn)
                            {
                                <MudTd DataLabel="Fixed width">
                                    <MudGrid>
                                        <MudItem xs="6">
                                            <MudNumericField T="int" @bind-Value="context.FixedWidthStartIndex" Label="Start" Min="0" ShrinkLabel />
                                        </MudItem>
                                        <MudItem xs="6">
                                            <MudNumericField T="int" @bind-Value="context.FixedWidthLength" Label="Length" Min="0" ShrinkLabel />
                                        </MudItem>
                                    </MudGrid>
                                </MudTd>
                            }
                            <MudTd DataLabel="Quantity">
                                <MudTextField Value="@context.PhysicalQuantity" ReadOnly="true" ShrinkLabel />
                            </MudTd>
                            <MudTd DataLabel="Unit">
                                <MudSelect T="string" Value="@context.Unit" ValueChanged="@((string unit) => context.Unit = unit)" Dense="true" ShrinkLabel Disabled="@(!SignalHasUnit(context.SignalKind))">
                                    @foreach (string unit in GetUnitChoices(context.SignalKind))
                                    {
                                        <MudSelectItem T="string" Value="@unit">@unit</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudTd>
                            <MudTd DataLabel="Depth reference">
                                <MudSelect T="string" Value="@context.DepthReferenceName" ValueChanged="@((string referenceName) => context.DepthReferenceName = referenceName)" Dense="true" ShrinkLabel Disabled="@(!SignalUsesDepthReference(context.SignalKind))">
                                    @foreach (string referenceName in DepthReferenceNames)
                                    {
                                        <MudSelectItem T="string" Value="@referenceName">@referenceName</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <MudText>No realtime signal mappings have been configured.</MudText>
                        </NoRecordsContent>
                    </MudTable>
                </MudExpansionPanel>
            </MudExpansionPanels>

            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.h6">Calibration Result</MudText>
                @if (currentCase_.BestCalibrationID is null)
                {
                    <MudText>No calibration result has been associated with this case yet.</MudText>
                }
                else if (isLoadingCalibration_)
                {
                    <MudProgressLinear Indeterminate="true" />
                }
                else if (selectedCalibration_ is null)
                {
                    <MudText>Calibration @currentCase_.BestCalibrationID could not be loaded.</MudText>
                }
                else
                {
                    <MudGrid>
                        <MudItem xs="12" md="3">
                            <MudText Typo="Typo.caption">Quality</MudText>
                            <MudText>@selectedCalibration_.Quality.ToString("F3")</MudText>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudText Typo="Typo.caption">Created</MudText>
                            <MudText>@FormatDate(selectedCalibration_.CreationDate)</MudText>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudText Typo="Typo.caption">Components</MudText>
                            <MudText>@selectedCalibration_.Components.Count</MudText>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudText Typo="Typo.caption">Model</MudText>
                            <MudText>@selectedCalibration_.ModelVersion</MudText>
                        </MudItem>
                    </MudGrid>
                    <MudTable Items="@selectedCalibration_.Components" T="CalibrationParameterSet" Dense="true" Hover="true" Class="mt-3">
                        <HeaderContent>
                            <MudTh>Component</MudTh>
                            <MudTh>Quality</MudTh>
                            <MudTh>Parameters</MudTh>
                            <MudTh>Message</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Component</MudTd>
                            <MudTd>@context.Quality.ToString("F3")</MudTd>
                            <MudTd>@context.Parameters.Count</MudTd>
                            <MudTd>@context.Message</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        }
    </MudStack>
    </MudUnitAndReferenceChoiceTag>
}

@code {
    private List<ActiveVolumeCaseLight>? cases_;
    private HashSet<ActiveVolumeCaseLight> selectedCases_ = new();
    private ActiveVolumeCaseLight? selectedCaseLight_;
    private ActiveVolumeCase? currentCase_;
    private CalibrationRecord? selectedCalibration_;
    private MudUnitAndReferenceChoiceTag? unitReferenceTag_;
    private HashSet<DelimitedColumnMapping> selectedImportColumns_ = new();
    private List<FieldLight> fieldList_ = new();
    private List<ClusterLight> clusterList_ = new();
    private List<Well> wellList_ = new();
    private List<WellBore> wellBoreList_ = new();
    private List<WellBoreArchitecture> wellBoreArchitectureList_ = new();
    private List<DrillStringLight> drillStringList_ = new();
    private List<Rig> rigList_ = new();
    private IBrowserFile? selectedRealtimeImportFile_;
    private bool isEditing_;
    private bool isLoadingCase_;
    private bool isLoadingCalibration_;
    private bool isBusy_;

    private Guid? SelectedFieldId => ToNullableGuid(currentCase_?.FieldID);
    private Guid? SelectedClusterId => ToNullableGuid(currentCase_?.ClusterID);
    private Guid? SelectedWellId => ToNullableGuid(currentCase_?.WellID);
    private Guid? SelectedWellBoreId => ToNullableGuid(currentCase_?.WellBoreID);
    private Guid? SelectedWellBoreArchitectureId => ToNullableGuid(currentCase_?.WellBoreArchitectureID);
    private Guid? SelectedDrillStringId => ToNullableGuid(currentCase_?.DrillStringID);
    private string DerivedRigName => GetDerivedRigName();
    private string DerivedMudSystem => GetDerivedMudSystem();
    private string DerivedHoleSection => GetDerivedHoleSection();
    private DelimitedImportDefinition RealtimeImportDefinition => EnsureRealtimeImportDefinition();
    private List<DelimitedColumnMapping> ImportColumns => RealtimeImportDefinition.Columns?
        .Where(mapping => IsSignalVisibleForSelectedImportFormat(mapping.SignalKind))
        .Where(mapping => IsSignalCompatibleWithReturnFlowMode(mapping.SignalKind, currentCase_?.ReturnFlowMeasurementMode ?? ReturnFlowMeasurementMode.FlowPaddle))
        .ToList() ?? new List<DelimitedColumnMapping>();
    private bool ShowImportSourceColumn => RealtimeImportDefinition.FileFormat != ActiveVolumeImportFileFormat.FixedWidthText;
    private bool ShowFixedWidthColumn => RealtimeImportDefinition.FileFormat == ActiveVolumeImportFileFormat.FixedWidthText;
    private bool ShowTimestampImportControls => RealtimeImportDefinition.FileFormat != ActiveVolumeImportFileFormat.Parquet;
    private bool CanImportRealtimeData => currentCase_ is not null && selectedRealtimeImportFile_ is not null && !isBusy_;

    private static IReadOnlyList<DelimitedFileSeparator> DelimitedSeparators { get; } =
        new[] { DelimitedFileSeparator.Comma, DelimitedFileSeparator.Semicolon, DelimitedFileSeparator.Tab, DelimitedFileSeparator.Whitespace, DelimitedFileSeparator.Custom };

    private static IReadOnlyList<string> DepthReferenceNames { get; } =
        new[] { "WGS84", "Rotary table", "Ground/Mud line", "Mean sea level", "Sea water level" };

    private static IReadOnlyList<string> TimeZoneIds { get; } =
        TimeZoneInfo.GetSystemTimeZones().Select(timeZone => timeZone.Id).ToList();

    private static IReadOnlyList<ReturnFlowMeasurementMode> ReturnFlowMeasurementModes { get; } =
        new[] { ReturnFlowMeasurementMode.FlowPaddle, ReturnFlowMeasurementMode.CoriolisFlowmeter };

    private static IReadOnlyList<ActiveVolumeSignalKind> BaseImportableSignalKinds { get; } =
        new[]
        {
            ActiveVolumeSignalKind.Ignore,
            ActiveVolumeSignalKind.Timestamp,
            ActiveVolumeSignalKind.RelativeSeconds,
            ActiveVolumeSignalKind.ActiveVolume,
            ActiveVolumeSignalKind.FlowrateIn,
            ActiveVolumeSignalKind.ReturnMudDensity,
            ActiveVolumeSignalKind.CuttingsRecoveryRate,
            ActiveVolumeSignalKind.CuttingsP50Size,
            ActiveVolumeSignalKind.StandPipePressure,
            ActiveVolumeSignalKind.InletMudTemperature,
            ActiveVolumeSignalKind.OutletMudTemperature,
            ActiveVolumeSignalKind.BottomOfStringDepth,
            ActiveVolumeSignalKind.BottomHoleDepth,
            ActiveVolumeSignalKind.AxialPipeVelocity,
            ActiveVolumeSignalKind.ShakerLoadEstimate
        };

    private List<FieldLight> AvailableFields =>
        fieldList_.Where(item => item?.MetaInfo != null).OrderBy(item => item.Name).ToList();

    private List<ClusterLight> AvailableClusters =>
        clusterList_
            .Where(item =>
                item?.MetaInfo != null &&
                !item.IsSingleWell &&
                (SelectedFieldId is null || item.FieldID == SelectedFieldId))
            .OrderBy(item => item.Name)
            .ToList();

    private List<Well> AvailableWells =>
        wellList_
            .Where(item =>
                item?.MetaInfo != null &&
                (SelectedClusterId is null || item.IsSingleWell || item.ClusterID == SelectedClusterId))
            .OrderBy(item => item.Name)
            .ToList();

    private List<WellBore> AvailableWellBores =>
        wellBoreList_
            .Where(item =>
                item?.MetaInfo != null &&
                (SelectedWellId is null || item.WellID == SelectedWellId))
            .OrderBy(item => item.Name)
            .ToList();

    private List<WellBoreArchitecture> AvailableWellBoreArchitectures =>
        wellBoreArchitectureList_
            .Where(item =>
                item?.MetaInfo != null &&
                (SelectedWellBoreId is null || item.WellBoreID == SelectedWellBoreId))
            .OrderBy(item => item.Name)
            .ToList();

    private List<DrillStringLight> AvailableDrillStrings =>
        drillStringList_
            .Where(item =>
                item?.MetaInfo != null &&
                (SelectedWellBoreId is null || item.WellBoreID == SelectedWellBoreId))
            .OrderBy(item => item.Name)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(ReloadCasesAsync(), LoadContextDataAsync());
    }

    private async Task ReloadCasesAsync()
    {
        cases_ = await Api.GetCasesAsync();
        selectedCases_.Clear();
    }

    private async Task LoadContextDataAsync()
    {
        Task<List<FieldLight>> fieldsTask = Api.GetFieldsAsync();
        Task<List<ClusterLight>> clustersTask = Api.GetClustersAsync();
        Task<List<Well>> wellsTask = Api.GetWellsAsync();
        Task<List<WellBore>> wellBoresTask = Api.GetWellBoresAsync();
        Task<List<WellBoreArchitecture>> architecturesTask = Api.GetWellBoreArchitecturesAsync();
        Task<List<DrillStringLight>> drillStringsTask = Api.GetDrillStringsAsync();
        Task<List<Rig>> rigsTask = Api.GetRigsAsync();

        await Task.WhenAll(fieldsTask, clustersTask, wellsTask, wellBoresTask, architecturesTask, drillStringsTask, rigsTask);

        fieldList_ = fieldsTask.Result;
        clusterList_ = clustersTask.Result;
        wellList_ = wellsTask.Result;
        wellBoreList_ = wellBoresTask.Result;
        wellBoreArchitectureList_ = architecturesTask.Result;
        drillStringList_ = drillStringsTask.Result;
        rigList_ = rigsTask.Result;
    }

    private Task CreateCaseAsync()
    {
        DateTimeOffset now = DateTimeOffset.UtcNow;
        currentCase_ = new ActiveVolumeCase
        {
            Id = Guid.Empty,
            Name = "New active volume case",
            ReturnFlowMeasurementMode = ReturnFlowMeasurementMode.FlowPaddle,
            CreationDate = now,
            LastModificationDate = now,
            ProcessingState = ActiveVolumeCaseProcessingState.Created,
            Tags = new Dictionary<string, string>(),
            RealtimeImportDefinition = CreateDefaultImportDefinition(ReturnFlowMeasurementMode.FlowPaddle),
            Chunks = new List<ActiveVolumeCaseChunk>()
        };
        selectedCaseLight_ = ToLight(currentCase_);
        selectedCalibration_ = null;
        isEditing_ = true;
        isLoadingCase_ = false;
        isLoadingCalibration_ = false;
        return Task.CompletedTask;
    }

    private async Task OnCaseRowClicked(TableRowClickEventArgs<ActiveVolumeCaseLight> args)
    {
        if (args.Item is null)
        {
            return;
        }

        ActiveVolumeCaseLight selectedCase = args.Item;
        selectedCaseLight_ = selectedCase;
        isEditing_ = true;
        isLoadingCase_ = true;
        selectedCalibration_ = null;
        currentCase_ = null;

        currentCase_ = await Api.GetCaseAsync(selectedCase.Id, includeChunks: false);
        EnsureRealtimeImportDefinition();
        isLoadingCase_ = false;

        if (currentCase_?.BestCalibrationID is Guid calibrationId)
        {
            isLoadingCalibration_ = true;
            selectedCalibration_ = await Api.GetCalibrationAsync(calibrationId);
            isLoadingCalibration_ = false;
        }
    }

    private async Task SaveCaseAsync()
    {
        if (currentCase_ is null)
        {
            return;
        }

        isBusy_ = true;
        EnsureRealtimeImportDefinition();
        UpdateDerivedContextFields();
        currentCase_.LastModificationDate = DateTimeOffset.UtcNow;
        bool saved = await Api.SaveCaseAsync(currentCase_);
        isBusy_ = false;
        Snackbar.Add(saved ? "Active volume case saved." : $"Could not save active volume case. {Api.LastErrorMessage}", saved ? Severity.Success : Severity.Error);
        await ReloadCasesAsync();
    }

    private async Task DeleteCaseAsync(ActiveVolumeCaseLight activeCase)
    {
        isBusy_ = true;
        bool deleted = await Api.DeleteCaseAsync(activeCase.Id);
        isBusy_ = false;
        Snackbar.Add(deleted ? "Active volume case deleted." : "Could not delete active volume case.", deleted ? Severity.Success : Severity.Error);
        if (currentCase_?.Id == activeCase.Id)
        {
            currentCase_ = null;
            selectedCaseLight_ = null;
            selectedCalibration_ = null;
            isEditing_ = false;
        }

        await ReloadCasesAsync();
    }

    private async Task DeleteSelectedCasesAsync()
    {
        List<ActiveVolumeCaseLight> casesToDelete = selectedCases_.ToList();
        if (casesToDelete.Count == 0)
        {
            return;
        }

        isBusy_ = true;
        int deletedCount = 0;
        foreach (ActiveVolumeCaseLight activeCase in casesToDelete)
        {
            if (await Api.DeleteCaseAsync(activeCase.Id))
            {
                deletedCount++;
            }
        }

        isBusy_ = false;
        Snackbar.Add($"Deleted {deletedCount} of {casesToDelete.Count} selected active volume cases.", deletedCount == casesToDelete.Count ? Severity.Success : Severity.Warning);
        await ReloadCasesAsync();
    }

    private async Task ProcessCaseAsync()
    {
        if (currentCase_ is null)
        {
            return;
        }

        isBusy_ = true;
        Guid? jobId = await Api.ProcessCaseAsync(currentCase_.Id);
        isBusy_ = false;
        Snackbar.Add(jobId.HasValue ? "Calibration processing queued." : "Could not queue calibration processing.", jobId.HasValue ? Severity.Success : Severity.Error);
        await ReloadCasesAsync();
        selectedCaseLight_ = cases_?.FirstOrDefault(item => item.Id == currentCase_.Id) ?? selectedCaseLight_;
    }

    private async Task CloseEditorAsync()
    {
        isEditing_ = false;
        currentCase_ = null;
        selectedCaseLight_ = null;
        selectedCalibration_ = null;
        await ReloadCasesAsync();
    }

