    private DelimitedImportDefinition EnsureRealtimeImportDefinition()
    {
        if (currentCase_ is null)
        {
            return CreateDefaultImportDefinition(ReturnFlowMeasurementMode.FlowPaddle);
        }

        currentCase_.RealtimeImportDefinition ??= CreateDefaultImportDefinition(currentCase_.ReturnFlowMeasurementMode);
        if (!ReturnFlowMeasurementModes.Contains(currentCase_.ReturnFlowMeasurementMode))
        {
            currentCase_.ReturnFlowMeasurementMode = ReturnFlowMeasurementMode.FlowPaddle;
        }

        currentCase_.RealtimeImportDefinition.Columns ??= new List<DelimitedColumnMapping>();
        foreach (DelimitedColumnMapping mapping in currentCase_.RealtimeImportDefinition.Columns)
        {
            ApplySignalDefaults(mapping, overwriteUnit: string.IsNullOrWhiteSpace(mapping.Unit));
        }

        return currentCase_.RealtimeImportDefinition;
    }

    private static DelimitedImportDefinition CreateDefaultImportDefinition(ReturnFlowMeasurementMode returnFlowMeasurementMode)
    {
        return new DelimitedImportDefinition
        {
            FileFormat = ActiveVolumeImportFileFormat.DelimitedText,
            Separator = DelimitedFileSeparator.Comma,
            CustomSeparator = ",",
            HasHeader = true,
            TimestampFormat = "O",
            TimestampStorageKind = TimestampStorageKind.Utc,
            LocalTimeZoneId = TimeZoneInfo.Local.Id,
            Columns = CreateDefaultImportMappings(returnFlowMeasurementMode)
        };
    }

    private static List<DelimitedColumnMapping> CreateDefaultImportMappings(ReturnFlowMeasurementMode returnFlowMeasurementMode)
    {
        List<ActiveVolumeSignalKind> defaultSignals = new()
        {
            ActiveVolumeSignalKind.Timestamp,
            ActiveVolumeSignalKind.ActiveVolume,
            ActiveVolumeSignalKind.FlowrateIn,
            ActiveVolumeSignalKind.ReturnMudDensity,
            ActiveVolumeSignalKind.CuttingsRecoveryRate,
            ActiveVolumeSignalKind.CuttingsP50Size,
            ActiveVolumeSignalKind.StandPipePressure,
            ActiveVolumeSignalKind.BottomOfStringDepth,
            ActiveVolumeSignalKind.BottomHoleDepth,
            ActiveVolumeSignalKind.InletMudTemperature,
            ActiveVolumeSignalKind.OutletMudTemperature
        };

        if (returnFlowMeasurementMode == ReturnFlowMeasurementMode.CoriolisFlowmeter)
        {
            defaultSignals.InsertRange(3, new[]
            {
                ActiveVolumeSignalKind.CoriolisVolumetricFlowrate
            });
        }
        else
        {
            defaultSignals.Insert(3, ActiveVolumeSignalKind.FlowPaddlePosition);
        }

        return defaultSignals
            .Select((signal, index) =>
            {
                DelimitedColumnMapping mapping = new()
                {
                    ColumnIndex = index,
                    FieldName = signal.ToString()
                };
                OnImportSignalKindChanged(mapping, signal);
                return mapping;
            })
            .ToList();
    }

    private void OnReturnFlowMeasurementModeChanged(ReturnFlowMeasurementMode mode)
    {
        if (currentCase_ is null)
        {
            return;
        }

        currentCase_.ReturnFlowMeasurementMode = mode;
        ReplaceReturnFlowImportMappings();
    }

    private IReadOnlyList<ActiveVolumeSignalKind> GetImportableSignalKinds()
    {
        ReturnFlowMeasurementMode mode = currentCase_?.ReturnFlowMeasurementMode ?? ReturnFlowMeasurementMode.FlowPaddle;
        List<ActiveVolumeSignalKind> signalKinds = BaseImportableSignalKinds.ToList();
        if (RealtimeImportDefinition.FileFormat == ActiveVolumeImportFileFormat.Parquet)
        {
            signalKinds.Remove(ActiveVolumeSignalKind.Timestamp);
        }

        if (mode == ReturnFlowMeasurementMode.CoriolisFlowmeter)
        {
            signalKinds.Add(ActiveVolumeSignalKind.CoriolisVolumetricFlowrate);
        }
        else
        {
            signalKinds.Add(ActiveVolumeSignalKind.FlowPaddlePosition);
        }

        return signalKinds;
    }

    private void ReplaceReturnFlowImportMappings()
    {
        DelimitedImportDefinition definition = RealtimeImportDefinition;
        definition.Columns ??= new List<DelimitedColumnMapping>();
        List<DelimitedColumnMapping> mappingsToRemove = definition.Columns
            .Where(mapping => IsReturnFlowModeSpecificSignal(mapping.SignalKind))
            .ToList();
        foreach (DelimitedColumnMapping mapping in mappingsToRemove)
        {
            definition.Columns.Remove(mapping);
        }

        foreach (ActiveVolumeSignalKind signalKind in GetReturnFlowSignals(currentCase_?.ReturnFlowMeasurementMode ?? ReturnFlowMeasurementMode.FlowPaddle))
        {
            if (definition.Columns.Any(mapping => mapping.SignalKind == signalKind))
            {
                continue;
            }

            DelimitedColumnMapping mapping = new()
            {
                ColumnIndex = definition.Columns.Count,
                FieldName = signalKind.ToString()
            };
            OnImportSignalKindChanged(mapping, signalKind);
            definition.Columns.Add(mapping);
        }
    }

    private static IReadOnlyList<ActiveVolumeSignalKind> GetReturnFlowSignals(ReturnFlowMeasurementMode mode) =>
        mode == ReturnFlowMeasurementMode.CoriolisFlowmeter
            ? new[] { ActiveVolumeSignalKind.CoriolisVolumetricFlowrate, ActiveVolumeSignalKind.ReturnMudDensity }
            : new[] { ActiveVolumeSignalKind.FlowPaddlePosition };

    private static bool IsReturnFlowModeSpecificSignal(ActiveVolumeSignalKind signalKind) =>
        signalKind is ActiveVolumeSignalKind.FlowPaddlePosition
            or ActiveVolumeSignalKind.CoriolisVolumetricFlowrate
            or ActiveVolumeSignalKind.CoriolisMassFlowrate;

    private static bool IsSignalCompatibleWithReturnFlowMode(ActiveVolumeSignalKind signalKind, ReturnFlowMeasurementMode mode) => signalKind switch
    {
        ActiveVolumeSignalKind.FlowPaddlePosition => mode == ReturnFlowMeasurementMode.FlowPaddle,
        ActiveVolumeSignalKind.CoriolisVolumetricFlowrate => mode == ReturnFlowMeasurementMode.CoriolisFlowmeter,
        ActiveVolumeSignalKind.CoriolisMassFlowrate => false,
        _ => true
    };

    private bool IsSignalVisibleForSelectedImportFormat(ActiveVolumeSignalKind signalKind)
    {
        return RealtimeImportDefinition.FileFormat != ActiveVolumeImportFileFormat.Parquet ||
            signalKind != ActiveVolumeSignalKind.Timestamp;
    }

