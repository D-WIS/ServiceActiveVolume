    private async Task ImportRealtimeDataAsync()
    {
        if (currentCase_ is null || selectedRealtimeImportFile_ is null)
        {
            return;
        }

        isBusy_ = true;
        try
        {
            EnsureRealtimeImportDefinition();
            if (currentCase_.Id == Guid.Empty && !await Api.SaveCaseAsync(currentCase_))
            {
                Snackbar.Add($"Could not save the case before importing data. {Api.LastErrorMessage}", Severity.Error);
                return;
            }

            List<ActiveVolumeSample> samples = RealtimeImportDefinition.FileFormat == ActiveVolumeImportFileFormat.Parquet
                ? await ReadParquetImportSamplesAsync(selectedRealtimeImportFile_, RealtimeImportDefinition)
                : await ReadRealtimeImportSamplesAsync(selectedRealtimeImportFile_, RealtimeImportDefinition);
            if (samples.Count == 0)
            {
                Snackbar.Add("No realtime samples were found in the selected file.", Severity.Warning);
                return;
            }

            const int chunkSize = 10000;
            int uploadedChunks = 0;
            for (int offset = 0; offset < samples.Count; offset += chunkSize)
            {
                List<ActiveVolumeSample> chunkSamples = samples.Skip(offset).Take(chunkSize).ToList();
                ActiveVolumeCaseChunk chunk = new()
                {
                    CaseID = currentCase_.Id,
                    ChunkIndex = offset / chunkSize,
                    StartTimeUtc = chunkSamples.First().TimestampUtc,
                    EndTimeUtc = chunkSamples.Last().TimestampUtc,
                    Samples = chunkSamples,
                    Checksum = ComputeChunkChecksum(chunkSamples)
                };

                if (!await Api.SaveCaseChunkAsync(currentCase_.Id, chunk.ChunkIndex, chunk))
                {
                    Snackbar.Add($"Could not upload chunk {chunk.ChunkIndex}.", Severity.Error);
                    return;
                }

                uploadedChunks++;
            }

            currentCase_ = await Api.GetCaseAsync(currentCase_.Id, includeChunks: false) ?? currentCase_;
            selectedCaseLight_ = ToLight(currentCase_);
            Snackbar.Add($"Imported {samples.Count} samples in {uploadedChunks} chunk(s).", Severity.Success);
            await ReloadCasesAsync();
        }
        catch (Exception exception)
        {
            Snackbar.Add($"Could not import realtime data: {exception.Message}", Severity.Error);
        }
        finally
        {
            isBusy_ = false;
        }
    }

    private async Task<List<ActiveVolumeSample>> ReadParquetImportSamplesAsync(IBrowserFile file, DelimitedImportDefinition definition)
    {
        using Stream browserStream = file.OpenReadStream(maxAllowedSize: 1024L * 1024L * 1024L);
        await using MemoryStream memoryStream = new();
        await browserStream.CopyToAsync(memoryStream);
        memoryStream.Position = 0;

        await using ParquetReader reader = await ParquetReader.CreateAsync(memoryStream);
        DataField[] dataFields = reader.Schema.GetDataFields();
        DataField timestampField = ResolveParquetTimestampField(dataFields);
        List<DelimitedColumnMapping> mappings = ImportColumns
            .Where(mapping => mapping.SignalKind is not ActiveVolumeSignalKind.Ignore and not ActiveVolumeSignalKind.Timestamp and not ActiveVolumeSignalKind.RelativeSeconds)
            .ToList();
        List<ActiveVolumeSample> samples = new();

        for (int rowGroupIndex = 0; rowGroupIndex < reader.RowGroupCount; rowGroupIndex++)
        {
            using ParquetRowGroupReader rowGroupReader = reader.OpenRowGroupReader(rowGroupIndex);
            int rowCount = checked((int)rowGroupReader.RowCount);
            object?[] timestampValues = await ReadParquetColumnValuesAsync(rowGroupReader, timestampField, rowCount);
            Dictionary<DelimitedColumnMapping, object?[]> columnValues = new();

            foreach (DelimitedColumnMapping mapping in mappings)
            {
                DataField field = ResolveParquetDataField(dataFields, mapping.FieldName);
                columnValues[mapping] = await ReadParquetColumnValuesAsync(rowGroupReader, field, rowCount);
            }

            for (int rowIndex = 0; rowIndex < rowCount; rowIndex++)
            {
                DateTimeOffset? timestampUtc = ConvertParquetTimestampToUtc(timestampValues[rowIndex]);
                if (!timestampUtc.HasValue)
                {
                    continue;
                }

                ActiveVolumeSample sample = new()
                {
                    TimestampUtc = timestampUtc.Value,
                    AdditionalSignals = new Dictionary<string, double>(),
                    QualityFlags = new Dictionary<string, string>(),
                    CuttingsParticleSizeDistribution = new List<double>()
                };

                foreach ((DelimitedColumnMapping mapping, object?[] values) in columnValues)
                {
                    double? value = ConvertParquetValueToDouble(values[rowIndex]);
                    if (value.HasValue)
                    {
                        AssignSampleValue(sample, mapping.SignalKind, ConvertToSI(value.Value, mapping));
                    }
                }

                samples.Add(sample);
            }
        }

        return samples.OrderBy(sample => sample.TimestampUtc).ToList();
    }

    private static DataField ResolveParquetTimestampField(DataField[] dataFields)
    {
        string[] timestampFieldNames =
        {
            "TIME",
            "TIMESTAMP",
            "Timestamp",
            "timestamp",
            "TimestampUtc",
            "timestampUtc",
            "DATETIME",
            "DateTime",
            "DATE_TIME",
            "date_time",
            "TIME_STAMP"
        };

        foreach (string fieldName in timestampFieldNames)
        {
            DataField? field = dataFields.FirstOrDefault(item => string.Equals(item.Name, fieldName, StringComparison.OrdinalIgnoreCase));
            if (field is not null)
            {
                return field;
            }
        }

        DataField? dateTimeField = dataFields.FirstOrDefault(item =>
            item.ClrType == typeof(DateTime) ||
            item.ClrType == typeof(DateTime?) ||
            item.ClrType == typeof(DateTimeOffset) ||
            item.ClrType == typeof(DateTimeOffset?));

        return dateTimeField ?? throw new InvalidOperationException("No timestamp column was found in the Parquet file.");
    }

    private static DataField ResolveParquetDataField(DataField[] dataFields, string fieldName)
    {
        DataField? field = dataFields.FirstOrDefault(item => string.Equals(item.Name, fieldName, StringComparison.OrdinalIgnoreCase));
        return field ?? throw new InvalidOperationException($"Column '{fieldName}' was not found in the Parquet file.");
    }

    private static async Task<object?[]> ReadParquetColumnValuesAsync(ParquetRowGroupReader rowGroupReader, DataField field, int rowCount)
    {
        Type clrType = Nullable.GetUnderlyingType(field.ClrType) ?? field.ClrType;
        if (clrType == typeof(double))
        {
            return await ReadParquetStructColumnValuesAsync<double>(rowGroupReader, field, rowCount);
        }
        if (clrType == typeof(float))
        {
            return await ReadParquetStructColumnValuesAsync<float>(rowGroupReader, field, rowCount);
        }
        if (clrType == typeof(int))
        {
            return await ReadParquetStructColumnValuesAsync<int>(rowGroupReader, field, rowCount);
        }
        if (clrType == typeof(long))
        {
            return await ReadParquetStructColumnValuesAsync<long>(rowGroupReader, field, rowCount);
        }
        if (clrType == typeof(short))
        {
            return await ReadParquetStructColumnValuesAsync<short>(rowGroupReader, field, rowCount);
        }
        if (clrType == typeof(decimal))
        {
            return await ReadParquetStructColumnValuesAsync<decimal>(rowGroupReader, field, rowCount);
        }
        if (clrType == typeof(DateTime))
        {
            return await ReadParquetStructColumnValuesAsync<DateTime>(rowGroupReader, field, rowCount);
        }
        if (clrType == typeof(DateTimeOffset))
        {
            return await ReadParquetStructColumnValuesAsync<DateTimeOffset>(rowGroupReader, field, rowCount);
        }
        if (clrType == typeof(string))
        {
            string[] values = new string[rowCount];
            await rowGroupReader.ReadAsync(field, values);
            return values.Cast<object?>().ToArray();
        }

        throw new InvalidOperationException($"Column '{field.Name}' uses unsupported Parquet type '{field.ClrType.Name}'.");
    }

    private static async Task<object?[]> ReadParquetStructColumnValuesAsync<T>(ParquetRowGroupReader rowGroupReader, DataField field, int rowCount)
        where T : struct
    {
        Type clrType = Nullable.GetUnderlyingType(field.ClrType) ?? field.ClrType;
        if (field.IsNullable || Nullable.GetUnderlyingType(field.ClrType) is not null)
        {
            T?[] values = new T?[rowCount];
            await rowGroupReader.ReadAsync<T>(field, values);
            return values.Cast<object?>().ToArray();
        }

        T[] nonNullableValues = new T[rowCount];
        await rowGroupReader.ReadAsync<T>(field, nonNullableValues);
        return nonNullableValues.Cast<object?>().ToArray();
    }

    private static DateTimeOffset? ConvertParquetTimestampToUtc(object? value)
    {
        return value switch
        {
            null => null,
            DateTimeOffset dateTimeOffset => dateTimeOffset.ToUniversalTime(),
            DateTime dateTime => dateTime.Kind == DateTimeKind.Unspecified
                ? new DateTimeOffset(DateTime.SpecifyKind(dateTime, DateTimeKind.Utc))
                : new DateTimeOffset(dateTime.ToUniversalTime()),
            string text when DateTimeOffset.TryParse(text, CultureInfo.InvariantCulture, DateTimeStyles.AssumeUniversal | DateTimeStyles.AdjustToUniversal, out DateTimeOffset parsed) => parsed,
            long unixMilliseconds => DateTimeOffset.FromUnixTimeMilliseconds(unixMilliseconds),
            int unixSeconds => DateTimeOffset.FromUnixTimeSeconds(unixSeconds),
            double unixSeconds => DateTimeOffset.FromUnixTimeMilliseconds(checked((long)(unixSeconds * 1000.0))),
            float unixSeconds => DateTimeOffset.FromUnixTimeMilliseconds(checked((long)(unixSeconds * 1000.0f))),
            _ => null
        };
    }

    private static double? ConvertParquetValueToDouble(object? value)
    {
        return value switch
        {
            null => null,
            double doubleValue => doubleValue,
            float floatValue => floatValue,
            decimal decimalValue => (double)decimalValue,
            int intValue => intValue,
            long longValue => longValue,
            short shortValue => shortValue,
            string text when double.TryParse(text, NumberStyles.Float, CultureInfo.InvariantCulture, out double parsed) => parsed,
            _ => null
        };
    }

    private async Task<List<ActiveVolumeSample>> ReadRealtimeImportSamplesAsync(IBrowserFile file, DelimitedImportDefinition definition)
    {
        using Stream stream = file.OpenReadStream(maxAllowedSize: 1024L * 1024L * 1024L);
        using StreamReader reader = new(stream);
        string content = await reader.ReadToEndAsync();
        string[] lines = content.Replace("\r\n", "\n").Replace('\r', '\n').Split('\n', StringSplitOptions.RemoveEmptyEntries);
        int startIndex = definition.HasHeader ? 1 : 0;
        DateTimeOffset? relativeOriginUtc = definition.RelativeTimeOriginUtc;
        List<ActiveVolumeSample> samples = new();

        for (int i = startIndex; i < lines.Length; i++)
        {
            string line = lines[i];
            if (string.IsNullOrWhiteSpace(line))
            {
                continue;
            }

            ActiveVolumeSample? sample = ParseRealtimeImportSample(line, definition, relativeOriginUtc);
            if (sample is not null)
            {
                samples.Add(sample);
            }
        }

        return samples.OrderBy(sample => sample.TimestampUtc).ToList();
    }

    private ActiveVolumeSample? ParseRealtimeImportSample(string line, DelimitedImportDefinition definition, DateTimeOffset? relativeOriginUtc)
    {
        List<DelimitedColumnMapping> mappings = ImportColumns
            .Where(mapping => mapping.SignalKind is not ActiveVolumeSignalKind.Ignore)
            .ToList();
        Dictionary<ActiveVolumeSignalKind, string> rawValues = new();
        string[]? columns = definition.FileFormat == ActiveVolumeImportFileFormat.FixedWidthText ? null : SplitDelimitedLine(line, definition);

        foreach (DelimitedColumnMapping mapping in mappings)
        {
            string? rawValue = definition.FileFormat == ActiveVolumeImportFileFormat.FixedWidthText
                ? ExtractFixedWidthValue(line, mapping)
                : ExtractDelimitedValue(columns, mapping.ColumnIndex);

            if (!string.IsNullOrWhiteSpace(rawValue))
            {
                rawValues[mapping.SignalKind] = rawValue.Trim();
            }
        }

        DateTimeOffset? timestampUtc = ResolveImportTimestamp(rawValues, mappings, definition, relativeOriginUtc);
        if (!timestampUtc.HasValue)
        {
            return null;
        }

        ActiveVolumeSample sample = new()
        {
            TimestampUtc = timestampUtc.Value,
            AdditionalSignals = new Dictionary<string, double>(),
            QualityFlags = new Dictionary<string, string>(),
            CuttingsParticleSizeDistribution = new List<double>()
        };

        foreach (DelimitedColumnMapping mapping in mappings)
        {
            if (mapping.SignalKind is ActiveVolumeSignalKind.Timestamp or ActiveVolumeSignalKind.RelativeSeconds)
            {
                continue;
            }

            if (!rawValues.TryGetValue(mapping.SignalKind, out string? rawValue) ||
                !double.TryParse(rawValue, NumberStyles.Float, CultureInfo.InvariantCulture, out double value))
            {
                continue;
            }

            AssignSampleValue(sample, mapping.SignalKind, ConvertToSI(value, mapping));
        }

        return sample;
    }

    private static string[] SplitDelimitedLine(string line, DelimitedImportDefinition definition)
    {
        return definition.Separator switch
        {
            DelimitedFileSeparator.Semicolon => line.Split(';'),
            DelimitedFileSeparator.Tab => line.Split('\t'),
            DelimitedFileSeparator.Whitespace => line.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries),
            DelimitedFileSeparator.Custom when !string.IsNullOrEmpty(definition.CustomSeparator) => line.Split(definition.CustomSeparator),
            _ => line.Split(',')
        };
    }

    private static string? ExtractDelimitedValue(string[]? columns, int columnIndex)
    {
        return columns is not null && columnIndex >= 0 && columnIndex < columns.Length ? columns[columnIndex] : null;
    }

    private static string? ExtractFixedWidthValue(string line, DelimitedColumnMapping mapping)
    {
        if (mapping.FixedWidthStartIndex < 0 || mapping.FixedWidthStartIndex >= line.Length || mapping.FixedWidthLength <= 0)
        {
            return null;
        }

        int length = Math.Min(mapping.FixedWidthLength, line.Length - mapping.FixedWidthStartIndex);
        return line.Substring(mapping.FixedWidthStartIndex, length);
    }

    private DateTimeOffset? ResolveImportTimestamp(
        Dictionary<ActiveVolumeSignalKind, string> rawValues,
        List<DelimitedColumnMapping> mappings,
        DelimitedImportDefinition definition,
        DateTimeOffset? relativeOriginUtc)
    {
        if (rawValues.TryGetValue(ActiveVolumeSignalKind.Timestamp, out string? timestampText))
        {
            DateTimeStyles styles = definition.TimestampStorageKind == TimestampStorageKind.Utc
                ? DateTimeStyles.AssumeUniversal | DateTimeStyles.AdjustToUniversal
                : DateTimeStyles.AssumeLocal;
            if (DateTimeOffset.TryParseExact(timestampText, definition.TimestampFormat, CultureInfo.InvariantCulture, styles, out DateTimeOffset exactTimestamp) ||
                DateTimeOffset.TryParse(timestampText, CultureInfo.InvariantCulture, styles, out exactTimestamp))
            {
                return definition.TimestampStorageKind == TimestampStorageKind.Utc
                    ? exactTimestamp.ToUniversalTime()
                    : ConvertLocalImportTimeToUtc(exactTimestamp.DateTime, definition.LocalTimeZoneId);
            }
        }

        if (rawValues.TryGetValue(ActiveVolumeSignalKind.RelativeSeconds, out string? relativeText) &&
            double.TryParse(relativeText, NumberStyles.Float, CultureInfo.InvariantCulture, out double relativeSeconds))
        {
            DateTimeOffset origin = relativeOriginUtc ?? DateTimeOffset.UtcNow;
            return origin.AddSeconds(relativeSeconds).ToUniversalTime();
        }

        return null;
    }

    private static DateTimeOffset ConvertLocalImportTimeToUtc(DateTime localTime, string timeZoneId)
    {
        if (string.IsNullOrWhiteSpace(timeZoneId))
        {
            return new DateTimeOffset(localTime).ToUniversalTime();
        }

        TimeZoneInfo timeZone = TimeZoneInfo.FindSystemTimeZoneById(timeZoneId);
        DateTime unspecifiedLocalTime = DateTime.SpecifyKind(localTime, DateTimeKind.Unspecified);
        return new DateTimeOffset(TimeZoneInfo.ConvertTimeToUtc(unspecifiedLocalTime, timeZone), TimeSpan.Zero);
    }

    private double ConvertToSI(double value, DelimitedColumnMapping mapping)
    {
        string unit = mapping.Unit?.Trim() ?? string.Empty;
        return unit switch
        {
            "" or "SI" or "1" => value,
            "%" => value / 100.0,
            "ppm" => value / 1000000.0,
            "min" => value * 60.0,
            "h" => value * 3600.0,
            "L" => value / 1000.0,
            "bbl" => value * 0.158987294928,
            "L/min" => value / 60000.0,
            "m3/min" => value / 60.0,
            "gpm" => value * 0.0000630901964,
            "bbl/min" => value * 0.158987294928 / 60.0,
            "kg/min" => value / 60.0,
            "lb/min" => value * 0.45359237 / 60.0,
            "sg" => value * 1000.0,
            "g/cm3" => value * 1000.0,
            "ppg" => value * 119.826427316,
            "bar" => value * 100000.0,
            "psi" => value * 6894.757293168,
            "MPa" => value * 1000000.0,
            "degC" => value + 273.15,
            "degF" => (value - 32.0) * 5.0 / 9.0 + 273.15,
            "ft" => value * 0.3048,
            "in" => value * 0.0254,
            "mm" => value / 1000.0,
            "ft/s" => value * 0.3048,
            "m/min" => value / 60.0,
            "ft/min" => value * 0.3048 / 60.0,
            _ => value
        };
    }

    private static void AssignSampleValue(ActiveVolumeSample sample, ActiveVolumeSignalKind signalKind, double value)
    {
        switch (signalKind)
        {
            case ActiveVolumeSignalKind.ActiveVolume:
                sample.ActiveVolume = value;
                break;
            case ActiveVolumeSignalKind.FlowrateIn:
                sample.FlowrateIn = value;
                break;
            case ActiveVolumeSignalKind.FlowPaddlePosition:
                sample.FlowPaddlePosition = value;
                break;
            case ActiveVolumeSignalKind.CoriolisVolumetricFlowrate:
                sample.CoriolisVolumetricFlowrate = value;
                break;
            case ActiveVolumeSignalKind.ReturnMudDensity:
                sample.ReturnMudDensity = value;
                break;
            case ActiveVolumeSignalKind.CuttingsRecoveryRate:
                sample.CuttingsRecoveryRate = value;
                break;
            case ActiveVolumeSignalKind.StandPipePressure:
                sample.StandPipePressure = value;
                break;
            case ActiveVolumeSignalKind.InletMudTemperature:
                sample.InletMudTemperature = value;
                break;
            case ActiveVolumeSignalKind.OutletMudTemperature:
                sample.OutletMudTemperature = value;
                break;
            case ActiveVolumeSignalKind.BottomOfStringDepth:
                sample.BottomOfStringDepth = value;
                break;
            case ActiveVolumeSignalKind.BottomHoleDepth:
                sample.BottomHoleDepth = value;
                break;
            case ActiveVolumeSignalKind.AxialPipeVelocity:
                sample.AxialPipeVelocity = value;
                break;
            case ActiveVolumeSignalKind.CuttingsP50Size:
                sample.AdditionalSignals["CuttingsP50Size"] = value;
                break;
            case ActiveVolumeSignalKind.ShakerLoadEstimate:
                sample.AdditionalSignals["ShakerLoadEstimate"] = value;
                break;
        }
    }

    private static string ComputeChunkChecksum(List<ActiveVolumeSample> samples)
    {
        string content = string.Join('\n', samples.Select(sample => $"{sample.TimestampUtc:O}|{sample.ActiveVolume}|{sample.FlowrateIn}|{sample.FlowPaddlePosition}|{sample.CoriolisVolumetricFlowrate}|{sample.ReturnMudDensity}"));
        return Convert.ToHexString(SHA256.HashData(Encoding.UTF8.GetBytes(content)));
    }

    private void ApplyParquetFieldNames()
    {
        foreach (DelimitedColumnMapping mapping in RealtimeImportDefinition.Columns ?? new List<DelimitedColumnMapping>())
        {
            string parquetFieldName = GetDefaultParquetFieldName(mapping.SignalKind);
            if (string.IsNullOrWhiteSpace(parquetFieldName))
            {
                continue;
            }

            string genericFieldName = mapping.SignalKind.ToString();
            if (string.IsNullOrWhiteSpace(mapping.FieldName) ||
                string.Equals(mapping.FieldName, genericFieldName, StringComparison.Ordinal))
            {
                mapping.FieldName = parquetFieldName;
            }
        }
    }

    private static void OnImportSignalKindChanged(DelimitedColumnMapping mapping, ActiveVolumeSignalKind signalKind)
    {
        mapping.SignalKind = signalKind;
        ApplySignalDefaults(mapping, overwriteUnit: true);
    }

    private static void ApplySignalDefaults(DelimitedColumnMapping mapping, bool overwriteUnit)
    {
        mapping.PhysicalQuantity = GetPhysicalQuantity(mapping.SignalKind);
        if (string.IsNullOrWhiteSpace(mapping.FieldName) ||
            string.Equals(mapping.FieldName, "Signal", StringComparison.Ordinal) ||
            Enum.TryParse(mapping.FieldName, out ActiveVolumeSignalKind _))
        {
            mapping.FieldName = GetDefaultParquetFieldName(mapping.SignalKind);
        }

        mapping.ReferenceSystem = SignalUsesDepthReference(mapping.SignalKind) ? "WGS84" : string.Empty;
        if (SignalUsesDepthReference(mapping.SignalKind) && string.IsNullOrWhiteSpace(mapping.DepthReferenceName))
        {
            mapping.DepthReferenceName = "WGS84";
        }
        else if (!SignalUsesDepthReference(mapping.SignalKind))
        {
            mapping.DepthReferenceName = string.Empty;
        }

        if (overwriteUnit)
        {
            mapping.Unit = GetDefaultUnit(mapping.SignalKind);
        }
    }

