@page "/activevolumecalibration/batch-imports"
@inject IActiveVolumeCalibrationAPIUtils Api

<h1>Batch Imports</h1>

@if (batchImports_ is null)
{
    <p>Loading...</p>
}
else if (batchImports_.Count == 0)
{
    <p>No batch imports have been created yet.</p>
}
else
{
    <table class="activevolumecalibration-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>State</th>
                <th>Progress</th>
                <th>Items</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in batchImports_)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.ProcessingState</td>
                    <td>@item.ProcessingProgress.ToString("P0")</td>
                    <td>@item.Items.Count</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<ActiveVolumeCaseBatchImport>? batchImports_;

    protected override async Task OnInitializedAsync()
    {
        batchImports_ = await Api.GetBatchImportsAsync();
    }
}
